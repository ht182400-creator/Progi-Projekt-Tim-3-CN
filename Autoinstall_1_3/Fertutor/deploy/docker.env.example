# 复制为 deploy/docker.env 后 docker compose 会自动加载（见下方说明）
# cp deploy/docker.env.example deploy/docker.env

POSTGRES_USER=fertutor
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fertutor
POSTGRES_PORT=5432

APP_PORT=8080

# 浏览器访问应用的 Origin（本机单端口）
FRONTEND_URL=http://localhost:8080

# 使用 Cloudflare/ngrok 等穿透时，改为 https://你的子域...（与浏览器地址栏一致）
# FRONTEND_URL=https://xxxx.trycloudflare.com

JWT_SECRET=replace-with-long-random-string
VERIFY_SECRET=replace-with-long-random-string
RESET_SECRET=replace-with-long-random-string

# 可选
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
